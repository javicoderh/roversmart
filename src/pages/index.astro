---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/global.css";
import fox2dImage from "../assets/fox2d.png";
import foxImage from "../assets/fox.png";
import foxMidImage from "../assets/foxMid.png";

const cloudinaryCloudName = import.meta.env.PUBLIC_CLOUDINARY_CLOUD_NAME ?? "";
const cloudinaryUploadPreset = import.meta.env.PUBLIC_CLOUDINARY_UPLOAD_PRESET ?? "";
const formspreeEndpoint = import.meta.env.PUBLIC_FORMSPREE_ENDPOINT ?? "";
const referencesLimit = 6;
const maxImageSizeMb = 5;
const maxImageWidth = 2560;
const maxImageHeight = 2560;

const roverMenuItems = [
  { label: "GRAFFITI MURAL", href: "https://www.roversmart.com/pintura" },
  { label: "PRINTS", href: "https://www.roversmart.com/prints" },
  { label: "GRÁFICAS", href: "https://www.roversmart.com/diseo-grfico" },
  { label: "VIDEOS", href: "https://www.roversmart.com/videos" },
  { label: "CLIENTES", href: "https://www.roversmart.com/clientes" },
  { label: "ENCARGOS/CONTACTO", href: "https://www.roversmart.com/contact", active: true }
];

const quoteSteps = [
  { index: "01", label: "Proceso", title: "Desglose del proceso", caption: "" },
  { index: "02", label: "Muro / soporte", title: "Muro / soporte", caption: "Medidas, fotos y ubicación" },
  { index: "03", label: "Diseño / concepto", title: "Diseño / concepto", caption: "A mayor nivel de complejidad" },
  { index: "04", label: "Datos / contacto", title: "Datos / contacto", caption: "Datos de contacto." }
];
---

<BaseLayout
  title="Cotiza tu mural"
  description="Cotizador visual para proyectos de muralismo, branding y arte mural."
>
  <header class="site-header-shell">
    <div class="site-header page-shell page-shell--header">
      <button class="mobile-menu-toggle" type="button" aria-expanded="false" aria-controls="mobile-nav" data-mobile-menu-toggle>
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M4 7.5h16M4 12h16M4 16.5h16" />
        </svg>
        <span class="sr-only">Abrir menú</span>
      </button>
      <a class="site-logo" href="https://www.roversmart.com" aria-label="Ir a roversmart.com">
        <img
          class="site-logo-image site-logo-desktop"
          src="https://dglb26w8rx2ld.cloudfront.net/000_clients/160215/file/1602159E5Mk1bl.png"
          alt="Rover Smart"
          loading="eager"
        />
        <img
          class="site-logo-image site-logo-mobile"
          src="https://dglb26w8rx2ld.cloudfront.net/000_clients/160215/file/1602159E5Mk1bl.png"
          alt=""
          loading="eager"
          aria-hidden="true"
        />
      </a>
      <nav class="site-nav" aria-label="Secciones principales de Rover Smart">
        {
          roverMenuItems.map((item) => (
            <a
              href={item.href}
              class:list={[item.active && "is-active"]}
              target="_self"
              rel="noreferrer"
            >
              {item.label}
            </a>
          ))
        }
      </nav>
      <nav class="mobile-nav" id="mobile-nav" aria-label="Secciones principales de Rover Smart en móvil" data-mobile-nav hidden>
        {
          roverMenuItems.map((item) => (
            <a
              href={item.href}
              class:list={[item.active && "is-active"]}
              target="_self"
              rel="noreferrer"
            >
              {item.label}
            </a>
          ))
        }
      </nav>
    </div>
  </header>

  <main class="page-shell mural-page">
    <section class="hero-panel">
      <div class="hero-panel__copy">
        <p class="eyebrow">Cotizador de murales</p>
        <h1>Cotiza tu mural</h1>
        <p class="hero-note">Solicitud y proceso de cotización.</p>
        <div class="hero-tags" aria-label="Características del flujo">
          <span>Respuesta 3-5 días</span>
          <span>Bocetos aparte</span>
        </div>
      </div>
      <aside class="hero-panel__aside" aria-label="Resumen del flujo">
        <p class="card-label">Ruta</p>
        <ol class="mini-route">
          {
            quoteSteps.map((step) => (
              <li>
                <strong>{step.index}</strong>
                <span>{step.label}</span>
              </li>
            ))
          }
        </ol>
        <a class="hero-link" href="#formulario" data-start-flow>Empezar</a>
      </aside>
    </section>

    <section class="form-shell" id="formulario" data-form-shell hidden aria-hidden="true" tabindex="-1">
      <div class="steps-progress" aria-label="Progreso del formulario">
        <div class="steps-progress__track" aria-hidden="true"></div>
        {
          quoteSteps.map((step, index) => (
            <button
              class:list={["step-chip", index === 0 && "is-active"]}
              type="button"
              data-step-chip
              data-step-target={index}
              aria-current={index === 0 ? "step" : "false"}
            >
              <span class="step-chip__circle">{step.index}</span>
              <span class="step-chip__text">
                <strong>{step.label}</strong>
              </span>
            </button>
          ))
        }
      </div>

      <form
        class="quote-form"
        data-quote-form
        data-cloudinary-cloud-name={cloudinaryCloudName}
        data-cloudinary-upload-preset={cloudinaryUploadPreset}
        data-formspree-endpoint={formspreeEndpoint}
      >
        <div class="form-stage">
          <div class="form-stage__main">
            {
              quoteSteps.map((step, index) => (
                <fieldset class:list={["quote-step", index === 0 && "is-active"]} data-step={index} hidden={index !== 0}>
                  <legend class="sr-only">{step.title}</legend>
                  <div class="section-card-head">
                    <p class="section-index">{step.index}</p>
                    <div>
                      <p class="section-tag">{step.label}</p>
                      <h2>{step.title}</h2>
                      {
                        index === 2 ? (
                          <div class="section-caption-flow">
                            <p>{step.caption}:</p>
                            <span>+ tiempo de ejecución</span>
                            <span aria-hidden="true">↓</span>
                            <span>+ materiales / colores</span>
                            <span aria-hidden="true">↓</span>
                            <span>+ valor</span>
                          </div>
                        ) : step.caption ? (
                          <p>{step.caption}</p>
                        ) : null
                        
                      }
                    </div>
                  </div>

                  {index === 0 && (
                    <div class="process-overview">
                      <ol>
                        <li>Cliente completa el formulario de cotización.</li>
                        <li>Cliente recibe la cotización en 3-5 días hábiles aprox. desde la solicitud.</li>
                        <li>De ser aprobada la cotización, el cliente debe abonar el 50% del ítem diseño.</li>
                        <li>Reunión cliente-artista.</li>
                        <li>Comienza el proceso de feedback para el diseño.</li>
                        <li>Aprobado el diseño, cliente debe abonar el 50% restante de este + ítem materiales y logística.</li>
                        <li>Proceso de compra de materiales.</li>
                        <li>Ejecución del mural.</li>
                        <li>Entrega del mural.</li>
                        <li>Pago final [máximo 5 días hábiles desde la entrega].</li>
                      </ol>
                    </div>
                  )}

                  {index === 1 && (
                    <div class="field-grid">
                      <label>
                        Alto [mts]
                        <input type="number" name="alto" placeholder="2.8 mts" min="0" step="0.1" data-dimension="alto" />
                      </label>
                      <label>
                        Ancho [mts]
                        <input type="number" name="ancho" placeholder="6.5 mts" min="0" step="0.1" data-dimension="ancho" />
                      </label>
                      <label class="full">
                        Fotografías muro/soporte [máx. 4]
                        <span class="file-upload-control">
                          <span class="file-upload-trigger">Adjuntar fotografías</span>
                          <input
                            class="file-upload-input"
                            type="file"
                            name="foto_frontal"
                            accept="image/*"
                            multiple
                            data-max-files="4"
                          />
                        </span>
                        <small class="field-help">Hasta 4 imágenes de {maxImageSizeMb} MB cada una.</small>
                      </label>
                      <label>
                        Ubicación
                        <input type="text" name="ubicacion" placeholder="país, ciudad, dirección" />
                      </label>
                      <label>
                        Estado muro/ soporte
                        <select name="estado">
                          <option value="">Seleccionar</option>
                          <option>Listo para pintar</option>
                          <option>Requiere mantención</option>
                        </select>
                      </label>
                      <div class="availability-grid full">
                        <label class="circle-option">
                          <input type="checkbox" name="bodega_disponible" value="Sí" />
                          <span class="circle-option__control" aria-hidden="true"></span>
                          <span>¿bodegas disponibles?</span>
                        </label>
                        <label class="circle-option">
                          <input type="checkbox" name="estacionamiento_disponible" value="Sí" />
                          <span class="circle-option__control" aria-hidden="true"></span>
                          <span>¿estacionamiento disponible?</span>
                        </label>
                      </div>
                      <label class="full">
                        Notas adicionales
                        <textarea
                          name="descripcion_muro"
                          rows="4"
                          placeholder="Detalles extra a considerar; flujo masivo de gente, vehículos transitando cerca, obstáculos de acceso para materiales, etc."
                        ></textarea>
                      </label>
                    </div>
                  )}

                  {index === 2 && (
                    <div class="field-grid">
                      <label class="full">
                        Nivel de complejidad [puedes cotizar más de un nivel]
                        <div class="mural-type-grid">
                          <label class="mural-type-option">
                            <img class="mural-type-option__image" src={fox2dImage.src} alt="" aria-hidden="true" />
                            <span class="mural-type-option__choice">
                              <input type="checkbox" name="tipo_mural" value="Minimal" />
                              <span class="circle-option__control" aria-hidden="true"></span>
                            </span>
                            <span class="mural-type-option__label">Minimal</span>
                          </label>
                          <label class="mural-type-option">
                            <img class="mural-type-option__image" src={foxMidImage.src} alt="" aria-hidden="true" />
                            <span class="mural-type-option__choice">
                              <input type="checkbox" name="tipo_mural" value="Intermedio" />
                              <span class="circle-option__control" aria-hidden="true"></span>
                            </span>
                            <span class="mural-type-option__label">Intermedio</span>
                          </label>
                          <label class="mural-type-option">
                            <img class="mural-type-option__image" src={foxImage.src} alt="" aria-hidden="true" />
                            <span class="mural-type-option__choice">
                              <input type="checkbox" name="tipo_mural" value="Detallado" />
                              <span class="circle-option__control" aria-hidden="true"></span>
                            </span>
                            <span class="mural-type-option__label">Detallado</span>
                          </label>
                        </div>
                      </label>
                      <label>
                        Contexto del mural
                        <select name="uso">
                          <option value="">Seleccionar</option>
                          <option>Decorativo personal</option>
                          <option>Negocio / marketing</option>
                          <option>Evento</option>
                          <option>Espacio público</option>
                        </select>
                      </label>
                      <label class="full">
                        Concepto creativo
                        <textarea name="idea" rows="5" placeholder="Desarrolla la idea de tu mural..."></textarea>
                      </label>
                      <label class="full">
                        Referencias (opcional)
                        <input type="file" name="referencias" multiple accept="image/*" data-references-input data-references-limit={referencesLimit} />
                        <small class="field-help">
                          Hasta {referencesLimit} imágenes.
                          <span data-references-count>0 seleccionadas</span>
                        </small>
                      </label>
                      <label class="full">
                        Protección
                        <div class="protection-options">
                          <label class="circle-option">
                            <input type="checkbox" name="proteccion" value="Sellante" />
                            <span class="circle-option__control" aria-hidden="true"></span>
                            <span>Sellante</span>
                          </label>
                        </div>
                      </label>
                    </div>
                  )}

                  {index === 3 && (
                    <div class="field-grid">
                      <label>
                        Nombre
                        <input type="text" name="nombre" placeholder="tu nombre / nombre empresa / marca" />
                      </label>
                      <label>
                        E-mail
                        <input type="email" name="email" placeholder="nombre@correo.com" required />
                      </label>
                      <label>
                        Teléfono
                        <input type="tel" name="telefono" placeholder="+56 9 ..." />
                      </label>
                      <label class="full">
                        Descripción del cliente
                        <textarea
                          name="tipo_cliente"
                          rows="4"
                          placeholder="describe a la persona, institución o marca que solicita el mural."
                        ></textarea>
                      </label>
                    </div>
                  )}

                  <div class="step-actions">
                    <button type="button" class="ghost-button" data-step-prev hidden={index === 0}>
                      Atrás
                    </button>
                    {
                      index < quoteSteps.length - 1 ? (
                        <button type="button" data-step-next>
                          Siguiente
                        </button>
                      ) : (
                        <button type="submit" data-submit-button>
                          Enviar
                        </button>
                      )
                    }
                  </div>
                </fieldset>
              ))
            }
            <p class="form-status" data-submit-status aria-live="polite">
              Respuesta estimada: 3-5 días.
            </p>
          </div>
        </div>
      </form>
    </section>
  </main>

  <script>
    const form = document.querySelector("[data-quote-form]");
    const stepPanels = Array.from(document.querySelectorAll("[data-step]"));
    const stepChips = Array.from(document.querySelectorAll("[data-step-chip]"));
    const nextButtons = Array.from(document.querySelectorAll("[data-step-next]"));
    const prevButtons = Array.from(document.querySelectorAll("[data-step-prev]"));
    const startFlowButton = document.querySelector("[data-start-flow]");
    const formShell = document.querySelector("[data-form-shell]");
    const submitStatus = document.querySelector("[data-submit-status]");
    const submitButton = document.querySelector("[data-submit-button]");
    const referencesInput = document.querySelector("[data-references-input]");
    const referencesCount = document.querySelector("[data-references-count]");
    const imageInputs = Array.from(document.querySelectorAll('input[type="file"]'));
    const mobileMenuToggle = document.querySelector("[data-mobile-menu-toggle]");
    const mobileNav = document.querySelector("[data-mobile-nav]");
    const maxImageSizeBytes = 5 * 1024 * 1024;
    const maxImageWidth = 2560;
    const maxImageHeight = 2560;
    let currentStep = 0;
    let flowStarted = false;

    const setStep = (targetStep) => {
      currentStep = Math.min(Math.max(targetStep, 0), stepPanels.length - 1);

      stepPanels.forEach((panel, index) => {
        const isActive = index === currentStep;
        panel.hidden = !isActive;
        panel.classList.toggle("is-active", isActive);
      });

      stepChips.forEach((chip, index) => {
        const state = index < currentStep ? "done" : index === currentStep ? "active" : "idle";
        chip.dataset.state = state;
        chip.classList.toggle("is-active", index === currentStep);
        chip.classList.toggle("is-done", index < currentStep);
        chip.setAttribute("aria-current", index === currentStep ? "step" : "false");
      });
    };

    const revealForm = () => {
      if (!(formShell instanceof HTMLElement) || flowStarted) return;

      flowStarted = true;
      formShell.hidden = false;
      formShell.setAttribute("aria-hidden", "false");
      requestAnimationFrame(() => {
        formShell.classList.add("is-visible");
        formShell.focus();
        formShell.scrollIntoView({ behavior: "smooth", block: "start" });
      });
    };

    const syncReferencesCount = () => {
      if (!(referencesInput instanceof HTMLInputElement) || !referencesCount) return;

      const filesCount = referencesInput.files?.length || 0;
      referencesCount.textContent = `${filesCount} seleccionada${filesCount === 1 ? "" : "s"}`;
    };

    const fileToImage = (file) =>
      new Promise((resolve, reject) => {
        const image = new Image();
        const objectUrl = URL.createObjectURL(file);

        image.onload = () => {
          resolve({ image, objectUrl });
        };

        image.onerror = () => {
          URL.revokeObjectURL(objectUrl);
          reject(new Error("No se pudo leer una de las imágenes seleccionadas."));
        };

        image.src = objectUrl;
      });

    const canvasToBlob = (canvas, quality) =>
      new Promise((resolve, reject) => {
        canvas.toBlob(
          (blob) => {
            if (!blob) {
              reject(new Error("No se pudo comprimir una de las imágenes seleccionadas."));
              return;
            }

            resolve(blob);
          },
          "image/jpeg",
          quality
        );
      });

    const optimizeImageFile = async (file) => {
      const { image, objectUrl } = await fileToImage(file);
      const needsResize = image.width > maxImageWidth || image.height > maxImageHeight;
      const needsCompression = file.size > maxImageSizeBytes;

      if (!needsResize && !needsCompression) {
        URL.revokeObjectURL(objectUrl);
        return file;
      }

      const ratio = Math.min(maxImageWidth / image.width, maxImageHeight / image.height, 1);
      const width = Math.round(image.width * ratio);
      const height = Math.round(image.height * ratio);
      const canvas = document.createElement("canvas");
      const context = canvas.getContext("2d");

      if (!context) {
        URL.revokeObjectURL(objectUrl);
        throw new Error("No se pudo preparar la compresión de imágenes.");
      }

      canvas.width = width;
      canvas.height = height;
      context.drawImage(image, 0, 0, width, height);

      let quality = 0.86;
      let blob = await canvasToBlob(canvas, quality);

      while (blob.size > maxImageSizeBytes && quality > 0.45) {
        quality -= 0.08;
        blob = await canvasToBlob(canvas, quality);
      }

      URL.revokeObjectURL(objectUrl);

      if (blob.size > maxImageSizeBytes) {
        throw new Error("Una imagen sigue siendo demasiado pesada incluso después de comprimirla.");
      }

      return new File([blob], file.name.replace(/\.\w+$/, ".jpg"), {
        type: "image/jpeg",
        lastModified: Date.now()
      });
    };

    const replaceInputFiles = (input, files) => {
      const dataTransfer = new DataTransfer();
      files.forEach((file) => dataTransfer.items.add(file));
      input.files = dataTransfer.files;
    };

    const uploadFileToCloudinary = async (file, cloudName, uploadPreset) => {
      const cloudinaryFormData = new FormData();
      cloudinaryFormData.append("file", file);
      cloudinaryFormData.append("upload_preset", uploadPreset);

      const response = await fetch(`https://api.cloudinary.com/v1_1/${cloudName}/image/upload`, {
        method: "POST",
        body: cloudinaryFormData
      });

      if (!response.ok) {
        throw new Error("No se pudo subir una imagen a Cloudinary.");
      }

      return response.json();
    };

    const collectValues = (formData) => {
      const payload = {};

      for (const [key, value] of formData.entries()) {
        if (value instanceof File) continue;

        if (payload[key]) {
          payload[key] = Array.isArray(payload[key]) ? [...payload[key], value] : [payload[key], value];
        } else {
          payload[key] = value;
        }
      }

      return payload;
    };

    const toList = (value) => {
      if (Array.isArray(value)) return value;
      if (typeof value === "string" && value) return [value];
      return [];
    };

    const yesNoFromValue = (value) => (value ? "Sí" : "No");

    const buildSubmissionPayload = (payload) => ({
      step_01_desgloce_del_proceso: [
        "1. Cliente completa el formulario de cotización.",
        "2. Cliente recibe la cotización en 3-5 días hábiles aprox. desde la solicitud.",
        "3. De ser aprobada la cotización, el cliente debe abonar el 50% del ítem diseño.",
        "4. Reunión cliente-artista.",
        "5. Comienza el proceso de feedback para el diseño.",
        "6. Aprobado el diseño, cliente debe abonar el 50% restante de este + ítem materiales y logística.",
        "7. Proceso de compra de materiales.",
        "8. Ejecución del mural.",
        "9. Entrega del mural.",
        "10. Pago final [máximo 5 días hábiles desde la entrega]."
      ].join("\n"),
      step_02_muro_soporte_medidas: `Alto: ${payload.alto || "-"} | Ancho: ${payload.ancho || "-"}`,
      step_02_fotografias_muro_soporte: payload.foto_frontal_urls || "Sin adjuntos",
      step_02_ubicacion: payload.ubicacion || "-",
      step_02_estado_muro_soporte: payload.estado || "-",
      step_02_bodegas_disponibles: yesNoFromValue(payload.bodega_disponible),
      step_02_estacionamiento_disponible: yesNoFromValue(payload.estacionamiento_disponible),
      step_02_notas_adicionales: payload.descripcion_muro || "-",
      step_03_nivel_de_complejidad: toList(payload.tipo_mural).join(", ") || "-",
      step_03_uso: payload.uso || "-",
      step_03_concepto_creativo: payload.idea || "-",
      step_03_referencias: payload.referencias_urls || "Sin adjuntos",
      step_03_proteccion: toList(payload.proteccion).join(", ") || "-",
      step_04_nombre: payload.nombre || "-",
      step_04_email: payload.email || "-",
      step_04_whatsapp: payload.telefono || "-",
      step_04_descripcion_del_cliente: payload.tipo_cliente || "-"
    });

    const appendUploadedAssets = async (formElement, payload, cloudName, uploadPreset) => {
      const fileInputs = Array.from(formElement.querySelectorAll('input[type="file"]'));
      const uploadedGroups = {};

      for (const input of fileInputs) {
        const files = Array.from(input.files || []);
        if (!files.length) continue;

        uploadedGroups[input.name] = [];

        for (const file of files) {
          const uploadResult = await uploadFileToCloudinary(file, cloudName, uploadPreset);
          uploadedGroups[input.name].push(uploadResult.secure_url);
        }
      }

      Object.entries(uploadedGroups).forEach(([key, urls]) => {
        payload[`${key}_urls`] = urls.join("\n");
      });
    };

    stepChips.forEach((chip) => {
      chip.addEventListener("click", () => {
        revealForm();
        const target = Number(chip.dataset.stepTarget || "0");
        setStep(target);
      });
    });

    nextButtons.forEach((button) => {
      button.addEventListener("click", () => {
        revealForm();
        setStep(currentStep + 1);
      });
    });

    prevButtons.forEach((button) => {
      button.addEventListener("click", () => {
        revealForm();
        setStep(currentStep - 1);
      });
    });

    startFlowButton?.addEventListener("click", (event) => {
      event.preventDefault();
      revealForm();
      setStep(0);
      const firstFocusable = formShell?.querySelector('input, select, textarea, button');
      if (firstFocusable instanceof HTMLElement) {
        setTimeout(() => firstFocusable.focus(), 220);
      }
    });

    referencesInput?.addEventListener("change", async () => {
      if (!(referencesInput instanceof HTMLInputElement)) return;

      const limit = Number(referencesInput.dataset.referencesLimit || "0");
      let files = Array.from(referencesInput.files || []);

      if (limit > 0 && files.length > limit) {
        files = files.slice(0, limit);
        replaceInputFiles(referencesInput, files);

        if (submitStatus) {
          submitStatus.textContent = `Máximo ${limit} referencias.`;
        }
      }

      try {
        const optimizedFiles = [];

        for (const file of files) {
          const optimizedFile = await optimizeImageFile(file);
          optimizedFiles.push(optimizedFile);
        }

        replaceInputFiles(referencesInput, optimizedFiles);

        if (submitStatus && optimizedFiles.some((file, index) => file !== files[index])) {
          submitStatus.textContent = "Se optimizaron referencias para acelerar el envío.";
        }
      } catch (error) {
        referencesInput.value = "";
        if (submitStatus) {
          submitStatus.textContent =
            error instanceof Error ? error.message : "Una referencia visual no cumple los requisitos.";
        }
      }

      syncReferencesCount();
    });

    imageInputs
      .filter((input) => input !== referencesInput)
      .forEach((input) => {
        input.addEventListener("change", async () => {
          if (!(input instanceof HTMLInputElement)) return;

          const limit = Number(input.dataset.maxFiles || "0");
          let files = Array.from(input.files || []);
          if (!files.length) return;

          if (limit > 0 && files.length > limit) {
            files = files.slice(0, limit);
            replaceInputFiles(input, files);

            if (submitStatus) {
              submitStatus.textContent = `Máximo ${limit} imágenes.`;
            }
          }

          try {
            const optimizedFiles = [];

            for (const file of files) {
              const optimizedFile = await optimizeImageFile(file);
              optimizedFiles.push(optimizedFile);
            }

            replaceInputFiles(input, optimizedFiles);

            if (submitStatus && optimizedFiles.some((file, index) => file !== files[index])) {
              submitStatus.textContent = "Se optimizó una o más imágenes.";
            }
          } catch (error) {
            input.value = "";
            if (submitStatus) {
              submitStatus.textContent =
                error instanceof Error ? error.message : "Una imagen no cumple los requisitos.";
            }
          }
        });
      });

    mobileMenuToggle?.addEventListener("click", () => {
      if (!(mobileNav instanceof HTMLElement) || !(mobileMenuToggle instanceof HTMLButtonElement)) return;

      const isOpen = mobileMenuToggle.getAttribute("aria-expanded") === "true";
      mobileMenuToggle.setAttribute("aria-expanded", String(!isOpen));
      mobileNav.hidden = isOpen;
      mobileNav.classList.toggle("is-open", !isOpen);
      document.body.classList.toggle("mobile-menu-open", !isOpen);
    });

    mobileNav?.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        if (!(mobileNav instanceof HTMLElement) || !(mobileMenuToggle instanceof HTMLButtonElement)) return;

        mobileMenuToggle.setAttribute("aria-expanded", "false");
        mobileNav.hidden = true;
        mobileNav.classList.remove("is-open");
        document.body.classList.remove("mobile-menu-open");
      });
    });

    form?.addEventListener("submit", async (event) => {
      event.preventDefault();

      if (!(form instanceof HTMLFormElement)) return;

      const cloudName = form.dataset.cloudinaryCloudName || "";
      const uploadPreset = form.dataset.cloudinaryUploadPreset || "";
      const formspreeEndpointValue = form.dataset.formspreeEndpoint || "";

      if (!cloudName || !uploadPreset || !formspreeEndpointValue) {
        if (submitStatus) {
          submitStatus.textContent = "Configura Cloudinary y Formspree antes de enviar.";
        }
        return;
      }

      const formData = new FormData(form);
      const rawPayload = collectValues(formData);

      try {
        if (submitButton instanceof HTMLButtonElement) {
          submitButton.disabled = true;
          submitButton.textContent = "Enviando...";
        }

        if (submitStatus) {
          submitStatus.textContent = "Subiendo imágenes...";
        }

        await appendUploadedAssets(form, rawPayload, cloudName, uploadPreset);

        const payload = buildSubmissionPayload(rawPayload);

        if (submitStatus) {
          submitStatus.textContent = "Enviando solicitud...";
        }

        const response = await fetch(formspreeEndpointValue, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            Accept: "application/json"
          },
          body: JSON.stringify(payload)
        });

        if (!response.ok) {
          throw new Error("Formspree rechazó el envío.");
        }

        form.reset();
        setStep(0);
        syncReferencesCount();

        if (submitStatus) {
          submitStatus.textContent = "Solicitud enviada correctamente.";
        }
      } catch (error) {
        if (submitStatus) {
          submitStatus.textContent =
            error instanceof Error ? error.message : "Ocurrió un problema al enviar la solicitud.";
        }
      } finally {
        if (submitButton instanceof HTMLButtonElement) {
          submitButton.disabled = false;
          submitButton.textContent = "Enviar";
        }
      }
    });

    setStep(0);
    syncReferencesCount();
  </script>
</BaseLayout>
