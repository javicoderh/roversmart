---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/global.css";

const cloudinaryCloudName = import.meta.env.PUBLIC_CLOUDINARY_CLOUD_NAME ?? "";
const cloudinaryUploadPreset = import.meta.env.PUBLIC_CLOUDINARY_UPLOAD_PRESET ?? "";
const formspreeEndpoint = import.meta.env.PUBLIC_FORMSPREE_ENDPOINT ?? "";
const referencesLimit = 6;
const maxImageSizeMb = 5;
const maxImageWidth = 2560;
const maxImageHeight = 2560;

const roverMenuItems = [
  { label: "GRAFFITI MURAL", href: "https://www.roversmart.com/pintura" },
  { label: "PRINTS", href: "https://www.roversmart.com/prints" },
  { label: "GRÁFICAS", href: "https://www.roversmart.com/diseo-grfico" },
  { label: "VIDEOS", href: "https://www.roversmart.com/videos" },
  { label: "CLIENTES", href: "https://www.roversmart.com/clientes" },
  { label: "ENCARGOS/CONTACTO", href: "https://www.roversmart.com/contact", active: true }
];

const quoteSteps = [
  { index: "01", label: "Muro", title: "Muro", caption: "Fotos, medidas y base." },
  { index: "02", label: "Lugar", title: "Ubica el proyecto", caption: "Acceso y condiciones." },
  { index: "03", label: "Idea", title: "Marca la dirección", caption: "Estilo, uso y referencias." },
  { index: "04", label: "Cierre", title: "Déjalo listo", caption: "Fecha, presupuesto y contacto." }
];
---

<BaseLayout
  title="Cotiza tu mural"
  description="Cotizador visual para proyectos de muralismo, branding y arte mural."
>
  <header class="site-header-shell">
    <div class="site-header page-shell page-shell--header">
      <button class="mobile-menu-toggle" type="button" aria-expanded="false" aria-controls="mobile-nav" data-mobile-menu-toggle>
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M4 7.5h16M4 12h16M4 16.5h16" />
        </svg>
        <span class="sr-only">Abrir menú</span>
      </button>
      <a class="site-logo" href="https://www.roversmart.com" aria-label="Ir a roversmart.com">
        <img
          class="site-logo-image site-logo-desktop"
          src="https://dglb26w8rx2ld.cloudfront.net/000_clients/160215/file/1602159E5Mk1bl.png"
          alt="Rover Smart"
          loading="eager"
        />
        <img
          class="site-logo-image site-logo-mobile"
          src="https://dglb26w8rx2ld.cloudfront.net/000_clients/160215/file/1602159E5Mk1bl.png"
          alt=""
          loading="eager"
          aria-hidden="true"
        />
      </a>
      <nav class="site-nav" aria-label="Secciones principales de Rover Smart">
        {
          roverMenuItems.map((item) => (
            <a
              href={item.href}
              class:list={[item.active && "is-active"]}
              target="_self"
              rel="noreferrer"
            >
              {item.label}
            </a>
          ))
        }
      </nav>
      <nav class="mobile-nav" id="mobile-nav" aria-label="Secciones principales de Rover Smart en móvil" data-mobile-nav hidden>
        {
          roverMenuItems.map((item) => (
            <a
              href={item.href}
              class:list={[item.active && "is-active"]}
              target="_self"
              rel="noreferrer"
            >
              {item.label}
            </a>
          ))
        }
      </nav>
    </div>
  </header>

  <main class="page-shell mural-page">
    <section class="hero-panel">
      <div class="hero-panel__copy">
        <p class="eyebrow">Cotizador mural</p>
        <h1>Cotiza tu mural en 4 pasos.</h1>
        <p class="hero-note">precio aprox en tiempo real.</p>
        <div class="hero-tags" aria-label="Características del flujo">
          <span>Respuesta 3-5 días</span>
          <span>Bocetos aparte</span>
        </div>
      </div>
      <aside class="hero-panel__aside" aria-label="Resumen del flujo">
        <p class="card-label">Ruta</p>
        <ol class="mini-route">
          {
            quoteSteps.map((step) => (
              <li>
                <strong>{step.index}</strong>
                <span>{step.label}</span>
              </li>
            ))
          }
        </ol>
        <a class="hero-link" href="#formulario" data-start-flow>Empezar</a>
      </aside>
    </section>

    <section class="form-shell" id="formulario" data-form-shell hidden aria-hidden="true" tabindex="-1">
      <div class="steps-progress" aria-label="Progreso del formulario">
        <div class="steps-progress__track" aria-hidden="true"></div>
        {
          quoteSteps.map((step, index) => (
            <button
              class:list={["step-chip", index === 0 && "is-active"]}
              type="button"
              data-step-chip
              data-step-target={index}
              aria-current={index === 0 ? "step" : "false"}
            >
              <span class="step-chip__circle">{step.index}</span>
              <span class="step-chip__text">
                <strong>{step.label}</strong>
                <small>{step.caption}</small>
              </span>
            </button>
          ))
        }
      </div>

      <form
        class="quote-form"
        data-quote-form
        data-cloudinary-cloud-name={cloudinaryCloudName}
        data-cloudinary-upload-preset={cloudinaryUploadPreset}
        data-formspree-endpoint={formspreeEndpoint}
      >
        <div class="form-stage">
          <div class="form-stage__main">
            {
              quoteSteps.map((step, index) => (
                <fieldset class:list={["quote-step", index === 0 && "is-active"]} data-step={index} hidden={index !== 0}>
                  <legend class="sr-only">{step.title}</legend>
                  <div class="section-card-head">
                    <p class="section-index">{step.index}</p>
                    <div>
                      <p class="section-tag">{step.label}</p>
                      <h2>{step.title}</h2>
                      <p>{step.caption}</p>
                    </div>
                  </div>

                  {index === 0 && (
                    <div class="field-grid">
                      <label class="full">
                        Frente
                        <input type="file" name="foto_frontal" accept="image/*" />
                        <small class="field-help">Hasta {maxImageSizeMb} MB.</small>
                      </label>
                      <label class="full">
                        Entorno
                        <input type="file" name="foto_entorno" accept="image/*" />
                        <small class="field-help">Hasta {maxImageSizeMb} MB.</small>
                      </label>
                      <label>
                        Alto
                        <input type="number" name="alto" placeholder="2.8" min="0" step="0.1" data-dimension="alto" />
                      </label>
                      <label>
                        Ancho
                        <input type="number" name="ancho" placeholder="6.5" min="0" step="0.1" data-dimension="ancho" />
                      </label>
                      <label>
                        Material
                        <select name="material">
                          <option value="">Seleccionar</option>
                          <option>Hormigón</option>
                          <option>Estuco</option>
                          <option>Ladrillo</option>
                          <option>Metal</option>
                          <option>Madera</option>
                        </select>
                      </label>
                      <label>
                        Estado
                        <select name="estado">
                          <option value="">Seleccionar</option>
                          <option>Nuevo</option>
                          <option>Pintado</option>
                          <option>Con humedad</option>
                          <option>Con grietas</option>
                          <option>Con grafitis previos</option>
                        </select>
                      </label>
                      <label class="full">
                        Zona
                        <input type="file" name="croquis" accept="image/*" />
                        <small class="field-help">Marca la parte a intervenir.</small>
                      </label>
                      <label>
                        Escala
                        <select name="escala_humana">
                          <option value="">Seleccionar</option>
                          <option>Persona en foto</option>
                          <option>Puerta o referencia</option>
                          <option>No disponible</option>
                        </select>
                      </label>
                      <label class="full">
                        Nota
                        <textarea name="descripcion_muro" rows="4" placeholder="Textura, reparaciones, observaciones."></textarea>
                      </label>
                    </div>
                  )}

                  {index === 1 && (
                    <div class="field-grid">
                      <label>
                        Ciudad
                        <input type="text" name="ubicacion" placeholder="Providencia, Santiago" />
                      </label>
                      <label>
                        Altura
                        <select name="altura">
                          <option value="">Seleccionar</option>
                          <option>A nivel de suelo</option>
                          <option>Segundo piso</option>
                          <option>Más alto</option>
                        </select>
                      </label>
                      <label>
                        Acceso
                        <select name="acceso">
                          <option value="">Seleccionar</option>
                          <option>Fácil acceso</option>
                          <option>Interior</option>
                          <option>Calle transitada</option>
                        </select>
                      </label>
                      <label>
                        Exposición
                        <select name="exposicion">
                          <option value="">Seleccionar</option>
                          <option>Sol directo</option>
                          <option>Interior</option>
                          <option>Exterior con lluvia</option>
                        </select>
                      </label>
                      <label class="full">
                        Logística
                        <textarea name="logistica" rows="4" placeholder="Andamio, permisos, horario, estacionamiento."></textarea>
                      </label>
                    </div>
                  )}

                  {index === 2 && (
                    <div class="field-grid">
                      <label>
                        Tipo
                        <select name="tipo_mural">
                          <option value="">Seleccionar</option>
                          <option>Decorativo</option>
                          <option>Realista</option>
                          <option>Tipográfico</option>
                          <option>Ilustración artística</option>
                          <option>Branding / logo</option>
                        </select>
                      </label>
                      <label>
                        Detalle
                        <select name="detalle" data-detail-level>
                          <option value="">Seleccionar</option>
                          <option>Bajo (formas simples)</option>
                          <option>Medio</option>
                          <option>Alto (realismo o mucho detalle)</option>
                        </select>
                      </label>
                      <label>
                        Diseño
                        <select name="diseno">
                          <option value="">Seleccionar</option>
                          <option>Lo diseña el artista</option>
                          <option>Ya tengo un diseño</option>
                        </select>
                      </label>
                      <label>
                        Uso
                        <select name="uso">
                          <option value="">Seleccionar</option>
                          <option>Decorativo personal</option>
                          <option>Negocio / marketing</option>
                          <option>Evento</option>
                          <option>Espacio público</option>
                        </select>
                      </label>
                      <label class="full">
                        Estilo
                        <div class="chip-group">
                          <label><input type="checkbox" name="estilo" value="surrealista" /> <span>surrealista</span></label>
                          <label><input type="checkbox" name="estilo" value="botánico" /> <span>botánico</span></label>
                          <label><input type="checkbox" name="estilo" value="abstracto" /> <span>abstracto</span></label>
                          <label><input type="checkbox" name="estilo" value="infantil" /> <span>infantil</span></label>
                          <label><input type="checkbox" name="estilo" value="naturaleza" /> <span>naturaleza</span></label>
                          <label><input type="checkbox" name="estilo" value="retrato" /> <span>retrato</span></label>
                          <label><input type="checkbox" name="estilo" value="tipografía" /> <span>tipografía</span></label>
                        </div>
                      </label>
                      <label class="full">
                        Idea
                        <textarea name="idea" rows="5" placeholder="Qué quieres transmitir y qué referencias te acercan a eso."></textarea>
                      </label>
                      <label class="full">
                        Referencias
                        <input type="file" name="referencias" multiple accept="image/*" data-references-input data-references-limit={referencesLimit} />
                        <small class="field-help">
                          Hasta {referencesLimit} imágenes.
                          <span data-references-count>0 seleccionadas</span>
                        </small>
                      </label>
                      <label class="full">
                        Protección
                        <div class="chip-group">
                          <label><input type="checkbox" name="proteccion" value="Sellado protector UV" /> <span>UV</span></label>
                          <label><input type="checkbox" name="proteccion" value="Barniz antigrafiti" /> <span>Antigrafiti</span></label>
                        </div>
                      </label>
                    </div>
                  )}

                  {index === 3 && (
                    <div class="field-grid">
                      <label class="full">
                        Fecha
                        <input type="date" name="fecha" />
                      </label>
                      <label>
                        Presupuesto
                        <select name="presupuesto">
                          <option value="">Seleccionar</option>
                          <option>Menos de $500.000 CLP</option>
                          <option>Entre $500.000 y $1.500.000 CLP</option>
                          <option>Entre $1.500.000 y $3.000.000 CLP</option>
                          <option>Más de $3.000.000 CLP</option>
                        </select>
                      </label>
                      <label>
                        Urgencia
                        <select name="urgencia">
                          <option value="">Seleccionar</option>
                          <option>Flexible</option>
                          <option>Fecha específica</option>
                        </select>
                      </label>
                      <label class="full">
                        Tiempos
                        <textarea name="comentarios_tiempo" rows="3" placeholder="Inauguración, campaña, fecha clave."></textarea>
                      </label>
                      <label>
                        Nombre
                        <input type="text" name="nombre" placeholder="Tu nombre" />
                      </label>
                      <label>
                        Email
                        <input type="email" name="email" placeholder="nombre@correo.com" required />
                      </label>
                      <label>
                        WhatsApp
                        <input type="tel" name="telefono" placeholder="+56 9 ..." />
                      </label>
                      <label>
                        Cliente
                        <select name="tipo_cliente">
                          <option value="">Seleccionar</option>
                          <option>Particular</option>
                          <option>Empresa</option>
                          <option>Municipalidad</option>
                          <option>Restaurante / local</option>
                        </select>
                      </label>
                    </div>
                  )}

                  <div class="step-actions">
                    <button type="button" class="ghost-button" data-step-prev hidden={index === 0}>
                      Atrás
                    </button>
                    {
                      index < quoteSteps.length - 1 ? (
                        <button type="button" data-step-next>
                          Siguiente
                        </button>
                      ) : (
                        <button type="submit" data-submit-button>
                          Enviar
                        </button>
                      )
                    }
                  </div>
                </fieldset>
              ))
            }
          </div>

          <aside class="estimate-card" aria-live="polite">
            <p class="estimate-label">Superficie</p>
            <p class="estimate-value"><span data-area-value>0.0</span> m²</p>
            <p class="estimate-price" data-price-value>$0 CLP</p>
            <p class="estimate-rate" data-rate-value>Base mural: $45.000 CLP/m²</p>
            <p class="estimate-copy" data-estimate-copy>
              Sube el muro y define el detalle.
            </p>
            <p class="estimate-market-note">
              Estimación referencial basada en rangos de muralismo y graffiti profesional.
            </p>
            <p class="estimate-status" data-submit-status>
              Respuesta estimada: 3-5 días.
            </p>
          </aside>
        </div>
      </form>
    </section>
  </main>

  <script>
    const form = document.querySelector("[data-quote-form]");
    const stepPanels = Array.from(document.querySelectorAll("[data-step]"));
    const stepChips = Array.from(document.querySelectorAll("[data-step-chip]"));
    const nextButtons = Array.from(document.querySelectorAll("[data-step-next]"));
    const prevButtons = Array.from(document.querySelectorAll("[data-step-prev]"));
    const startFlowButton = document.querySelector("[data-start-flow]");
    const formShell = document.querySelector("[data-form-shell]");
    const altoInput = document.querySelector('[data-dimension="alto"]');
    const anchoInput = document.querySelector('[data-dimension="ancho"]');
    const detailInput = document.querySelector("[data-detail-level]");
    const materialInput = document.querySelector('[name="material"]');
    const estadoInput = document.querySelector('[name="estado"]');
    const alturaInput = document.querySelector('[name="altura"]');
    const accesoInput = document.querySelector('[name="acceso"]');
    const exposicionInput = document.querySelector('[name="exposicion"]');
    const tipoMuralInput = document.querySelector('[name="tipo_mural"]');
    const disenoInput = document.querySelector('[name="diseno"]');
    const usoInput = document.querySelector('[name="uso"]');
    const urgenciaInput = document.querySelector('[name="urgencia"]');
    const protectionInputs = Array.from(document.querySelectorAll('input[name="proteccion"]'));
    const areaValue = document.querySelector("[data-area-value]");
    const priceValue = document.querySelector("[data-price-value]");
    const rateValue = document.querySelector("[data-rate-value]");
    const estimateCopy = document.querySelector("[data-estimate-copy]");
    const submitStatus = document.querySelector("[data-submit-status]");
    const submitButton = document.querySelector("[data-submit-button]");
    const referencesInput = document.querySelector("[data-references-input]");
    const referencesCount = document.querySelector("[data-references-count]");
    const imageInputs = Array.from(document.querySelectorAll('input[type="file"]'));
    const mobileMenuToggle = document.querySelector("[data-mobile-menu-toggle]");
    const mobileNav = document.querySelector("[data-mobile-nav]");
    const maxImageSizeBytes = 5 * 1024 * 1024;
    const maxImageWidth = 2560;
    const maxImageHeight = 2560;
    let currentStep = 0;
    let flowStarted = false;
    const basePricePerSquareMeter = 45000;

    const detailMap = {
      "Bajo (formas simples)": "lectura directa.",
      Medio: "detalle medio.",
      "Alto (realismo o mucho detalle)": "detalle alto."
    };

    const formatCurrency = (value) =>
      new Intl.NumberFormat("es-CL", {
        style: "currency",
        currency: "CLP",
        maximumFractionDigits: 0
      }).format(Math.round(value));

    const getValue = (input) => (input instanceof HTMLInputElement || input instanceof HTMLSelectElement ? input.value : "");

    const getProtectionMultiplier = () => {
      let multiplier = 1;

      protectionInputs.forEach((input) => {
        if (!(input instanceof HTMLInputElement) || !input.checked) return;
        if (input.value === "Sellado protector UV") multiplier += 0.05;
        if (input.value === "Barniz antigrafiti") multiplier += 0.08;
      });

      return multiplier;
    };

    const getAreaMultiplier = (area) => {
      if (!area) return 1;
      if (area < 5) return 1.32;
      if (area < 15) return 1.12;
      if (area < 40) return 1;
      if (area < 80) return 0.92;
      return 0.86;
    };

    const getSelectionMultiplier = () => {
      const multipliers = [
        {
          value: getValue(detailInput),
          map: {
            "Bajo (formas simples)": 0.9,
            Medio: 1,
            "Alto (realismo o mucho detalle)": 1.28
          }
        },
        {
          value: getValue(materialInput),
          map: {
            Hormigón: 1,
            Estuco: 1,
            Ladrillo: 1.08,
            Metal: 1.12,
            Madera: 1.07
          }
        },
        {
          value: getValue(estadoInput),
          map: {
            Nuevo: 1,
            Pintado: 1.04,
            "Con humedad": 1.18,
            "Con grietas": 1.15,
            "Con grafitis previos": 1.12
          }
        },
        {
          value: getValue(alturaInput),
          map: {
            "A nivel de suelo": 1,
            "Segundo piso": 1.12,
            "Más alto": 1.24
          }
        },
        {
          value: getValue(accesoInput),
          map: {
            "Fácil acceso": 1,
            Interior: 1.05,
            "Calle transitada": 1.08
          }
        },
        {
          value: getValue(exposicionInput),
          map: {
            "Sol directo": 1.04,
            Interior: 1,
            "Exterior con lluvia": 1.08
          }
        },
        {
          value: getValue(tipoMuralInput),
          map: {
            Decorativo: 0.94,
            Realista: 1.3,
            Tipográfico: 1.02,
            "Ilustración artística": 1.18,
            "Branding / logo": 1.08
          }
        },
        {
          value: getValue(disenoInput),
          map: {
            "Lo diseña el artista": 1.16,
            "Ya tengo un diseño": 1
          }
        },
        {
          value: getValue(usoInput),
          map: {
            "Decorativo personal": 0.98,
            "Negocio / marketing": 1.08,
            Evento: 1.12,
            "Espacio público": 1.1
          }
        },
        {
          value: getValue(urgenciaInput),
          map: {
            Flexible: 1,
            "Fecha específica": 1.14
          }
        }
      ];

      return multipliers.reduce((accumulator, item) => accumulator * (item.map[item.value] || 1), getProtectionMultiplier());
    };

    const setStep = (targetStep) => {
      currentStep = Math.min(Math.max(targetStep, 0), stepPanels.length - 1);

      stepPanels.forEach((panel, index) => {
        const isActive = index === currentStep;
        panel.hidden = !isActive;
        panel.classList.toggle("is-active", isActive);
      });

      stepChips.forEach((chip, index) => {
        const state = index < currentStep ? "done" : index === currentStep ? "active" : "idle";
        chip.dataset.state = state;
        chip.classList.toggle("is-active", index === currentStep);
        chip.classList.toggle("is-done", index < currentStep);
        chip.setAttribute("aria-current", index === currentStep ? "step" : "false");
      });
    };

    const revealForm = () => {
      if (!(formShell instanceof HTMLElement) || flowStarted) return;

      flowStarted = true;
      formShell.hidden = false;
      formShell.setAttribute("aria-hidden", "false");
      requestAnimationFrame(() => {
        formShell.classList.add("is-visible");
        formShell.focus();
        formShell.scrollIntoView({ behavior: "smooth", block: "start" });
      });
    };

    const updateEstimate = () => {
      const alto = Number(altoInput?.value || 0);
      const ancho = Number(anchoInput?.value || 0);
      const area = alto > 0 && ancho > 0 ? alto * ancho : 0;
      const detail = detailInput instanceof HTMLSelectElement ? detailInput.value : "";
      const totalMultiplier = getSelectionMultiplier() * getAreaMultiplier(area);
      const estimatedRate = basePricePerSquareMeter * totalMultiplier;
      const estimatedTotal = area * estimatedRate;

      if (areaValue) {
        areaValue.textContent = area.toFixed(1);
      }

      if (priceValue) {
        priceValue.textContent = area ? formatCurrency(estimatedTotal) : "$0 CLP";
      }

      if (rateValue) {
        rateValue.textContent = area
          ? `${formatCurrency(estimatedRate)} / m²`
          : `Base mural: ${formatCurrency(basePricePerSquareMeter)} / m²`;
      }

      if (!estimateCopy) return;

      if (!area) {
        estimateCopy.textContent = "Sube el muro y define el detalle.";
        return;
      }

      const scope = area < 5 ? "Formato chico." : area < 15 ? "Formato medio." : "Gran formato.";
      const complexity = detailMap[detail] || "Falta detalle.";

      estimateCopy.textContent = `${scope} ${area.toFixed(1)} m², ${complexity}`;
    };

    const syncReferencesCount = () => {
      if (!(referencesInput instanceof HTMLInputElement) || !referencesCount) return;

      const filesCount = referencesInput.files?.length || 0;
      referencesCount.textContent = `${filesCount} seleccionada${filesCount === 1 ? "" : "s"}`;
    };

    const fileToImage = (file) =>
      new Promise((resolve, reject) => {
        const image = new Image();
        const objectUrl = URL.createObjectURL(file);

        image.onload = () => {
          resolve({ image, objectUrl });
        };

        image.onerror = () => {
          URL.revokeObjectURL(objectUrl);
          reject(new Error("No se pudo leer una de las imágenes seleccionadas."));
        };

        image.src = objectUrl;
      });

    const canvasToBlob = (canvas, quality) =>
      new Promise((resolve, reject) => {
        canvas.toBlob(
          (blob) => {
            if (!blob) {
              reject(new Error("No se pudo comprimir una de las imágenes seleccionadas."));
              return;
            }

            resolve(blob);
          },
          "image/jpeg",
          quality
        );
      });

    const optimizeImageFile = async (file) => {
      const { image, objectUrl } = await fileToImage(file);
      const needsResize = image.width > maxImageWidth || image.height > maxImageHeight;
      const needsCompression = file.size > maxImageSizeBytes;

      if (!needsResize && !needsCompression) {
        URL.revokeObjectURL(objectUrl);
        return file;
      }

      const ratio = Math.min(maxImageWidth / image.width, maxImageHeight / image.height, 1);
      const width = Math.round(image.width * ratio);
      const height = Math.round(image.height * ratio);
      const canvas = document.createElement("canvas");
      const context = canvas.getContext("2d");

      if (!context) {
        URL.revokeObjectURL(objectUrl);
        throw new Error("No se pudo preparar la compresión de imágenes.");
      }

      canvas.width = width;
      canvas.height = height;
      context.drawImage(image, 0, 0, width, height);

      let quality = 0.86;
      let blob = await canvasToBlob(canvas, quality);

      while (blob.size > maxImageSizeBytes && quality > 0.45) {
        quality -= 0.08;
        blob = await canvasToBlob(canvas, quality);
      }

      URL.revokeObjectURL(objectUrl);

      if (blob.size > maxImageSizeBytes) {
        throw new Error("Una imagen sigue siendo demasiado pesada incluso después de comprimirla.");
      }

      return new File([blob], file.name.replace(/\.\w+$/, ".jpg"), {
        type: "image/jpeg",
        lastModified: Date.now()
      });
    };

    const replaceInputFiles = (input, files) => {
      const dataTransfer = new DataTransfer();
      files.forEach((file) => dataTransfer.items.add(file));
      input.files = dataTransfer.files;
    };

    const uploadFileToCloudinary = async (file, cloudName, uploadPreset) => {
      const cloudinaryFormData = new FormData();
      cloudinaryFormData.append("file", file);
      cloudinaryFormData.append("upload_preset", uploadPreset);

      const response = await fetch(`https://api.cloudinary.com/v1_1/${cloudName}/image/upload`, {
        method: "POST",
        body: cloudinaryFormData
      });

      if (!response.ok) {
        throw new Error("No se pudo subir una imagen a Cloudinary.");
      }

      return response.json();
    };

    const collectValues = (formData) => {
      const payload = {};

      for (const [key, value] of formData.entries()) {
        if (value instanceof File) continue;

        if (payload[key]) {
          payload[key] = Array.isArray(payload[key]) ? [...payload[key], value] : [payload[key], value];
        } else {
          payload[key] = value;
        }
      }

      return payload;
    };

    const appendUploadedAssets = async (formElement, payload, cloudName, uploadPreset) => {
      const fileInputs = Array.from(formElement.querySelectorAll('input[type="file"]'));
      const uploadedGroups = {};

      for (const input of fileInputs) {
        const files = Array.from(input.files || []);
        if (!files.length) continue;

        uploadedGroups[input.name] = [];

        for (const file of files) {
          const uploadResult = await uploadFileToCloudinary(file, cloudName, uploadPreset);
          uploadedGroups[input.name].push(uploadResult.secure_url);
        }
      }

      Object.entries(uploadedGroups).forEach(([key, urls]) => {
        payload[`${key}_urls`] = urls.join("\n");
      });
    };

    stepChips.forEach((chip) => {
      chip.addEventListener("click", () => {
        revealForm();
        const target = Number(chip.dataset.stepTarget || "0");
        setStep(target);
      });
    });

    nextButtons.forEach((button) => {
      button.addEventListener("click", () => {
        revealForm();
        setStep(currentStep + 1);
      });
    });

    prevButtons.forEach((button) => {
      button.addEventListener("click", () => {
        revealForm();
        setStep(currentStep - 1);
      });
    });

    startFlowButton?.addEventListener("click", (event) => {
      event.preventDefault();
      revealForm();
      setStep(0);
      const firstFocusable = formShell?.querySelector('input, select, textarea, button');
      if (firstFocusable instanceof HTMLElement) {
        setTimeout(() => firstFocusable.focus(), 220);
      }
    });

    altoInput?.addEventListener("input", updateEstimate);
    anchoInput?.addEventListener("input", updateEstimate);
    detailInput?.addEventListener("change", updateEstimate);
    [
      materialInput,
      estadoInput,
      alturaInput,
      accesoInput,
      exposicionInput,
      tipoMuralInput,
      disenoInput,
      usoInput,
      urgenciaInput
    ].forEach((input) => {
      input?.addEventListener("change", updateEstimate);
    });
    protectionInputs.forEach((input) => input.addEventListener("change", updateEstimate));

    referencesInput?.addEventListener("change", async () => {
      if (!(referencesInput instanceof HTMLInputElement)) return;

      const limit = Number(referencesInput.dataset.referencesLimit || "0");
      let files = Array.from(referencesInput.files || []);

      if (limit > 0 && files.length > limit) {
        files = files.slice(0, limit);
        replaceInputFiles(referencesInput, files);

        if (submitStatus) {
          submitStatus.textContent = `Máximo ${limit} referencias.`;
        }
      }

      try {
        const optimizedFiles = [];

        for (const file of files) {
          const optimizedFile = await optimizeImageFile(file);
          optimizedFiles.push(optimizedFile);
        }

        replaceInputFiles(referencesInput, optimizedFiles);

        if (submitStatus && optimizedFiles.some((file, index) => file !== files[index])) {
          submitStatus.textContent = "Se optimizaron referencias para acelerar el envío.";
        }
      } catch (error) {
        referencesInput.value = "";
        if (submitStatus) {
          submitStatus.textContent =
            error instanceof Error ? error.message : "Una referencia visual no cumple los requisitos.";
        }
      }

      syncReferencesCount();
    });

    imageInputs
      .filter((input) => input !== referencesInput)
      .forEach((input) => {
        input.addEventListener("change", async () => {
          if (!(input instanceof HTMLInputElement)) return;

          const files = Array.from(input.files || []);
          if (!files.length) return;

          try {
            const optimizedFiles = [];

            for (const file of files) {
              const optimizedFile = await optimizeImageFile(file);
              optimizedFiles.push(optimizedFile);
            }

            replaceInputFiles(input, optimizedFiles);

            if (submitStatus && optimizedFiles.some((file, index) => file !== files[index])) {
              submitStatus.textContent = "Se optimizó una o más imágenes.";
            }
          } catch (error) {
            input.value = "";
            if (submitStatus) {
              submitStatus.textContent =
                error instanceof Error ? error.message : "Una imagen no cumple los requisitos.";
            }
          }
        });
      });

    mobileMenuToggle?.addEventListener("click", () => {
      if (!(mobileNav instanceof HTMLElement) || !(mobileMenuToggle instanceof HTMLButtonElement)) return;

      const isOpen = mobileMenuToggle.getAttribute("aria-expanded") === "true";
      mobileMenuToggle.setAttribute("aria-expanded", String(!isOpen));
      mobileNav.hidden = isOpen;
      mobileNav.classList.toggle("is-open", !isOpen);
      document.body.classList.toggle("mobile-menu-open", !isOpen);
    });

    mobileNav?.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        if (!(mobileNav instanceof HTMLElement) || !(mobileMenuToggle instanceof HTMLButtonElement)) return;

        mobileMenuToggle.setAttribute("aria-expanded", "false");
        mobileNav.hidden = true;
        mobileNav.classList.remove("is-open");
        document.body.classList.remove("mobile-menu-open");
      });
    });

    form?.addEventListener("submit", async (event) => {
      event.preventDefault();

      if (!(form instanceof HTMLFormElement)) return;

      const cloudName = form.dataset.cloudinaryCloudName || "";
      const uploadPreset = form.dataset.cloudinaryUploadPreset || "";
      const formspreeEndpointValue = form.dataset.formspreeEndpoint || "";

      if (!cloudName || !uploadPreset || !formspreeEndpointValue) {
        if (submitStatus) {
          submitStatus.textContent = "Configura Cloudinary y Formspree antes de enviar.";
        }
        return;
      }

      const formData = new FormData(form);
      const payload = collectValues(formData);
      payload.superficie_estimada_m2 = areaValue?.textContent || "0.0";
      payload.resumen_preliminar = estimateCopy?.textContent || "";

      try {
        if (submitButton instanceof HTMLButtonElement) {
          submitButton.disabled = true;
          submitButton.textContent = "Enviando...";
        }

        if (submitStatus) {
          submitStatus.textContent = "Subiendo imágenes...";
        }

        await appendUploadedAssets(form, payload, cloudName, uploadPreset);

        if (submitStatus) {
          submitStatus.textContent = "Enviando solicitud...";
        }

        const response = await fetch(formspreeEndpointValue, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            Accept: "application/json"
          },
          body: JSON.stringify(payload)
        });

        if (!response.ok) {
          throw new Error("Formspree rechazó el envío.");
        }

        form.reset();
        setStep(0);
        updateEstimate();
        syncReferencesCount();

        if (submitStatus) {
          submitStatus.textContent = "Solicitud enviada correctamente.";
        }
      } catch (error) {
        if (submitStatus) {
          submitStatus.textContent =
            error instanceof Error ? error.message : "Ocurrió un problema al enviar la solicitud.";
        }
      } finally {
        if (submitButton instanceof HTMLButtonElement) {
          submitButton.disabled = false;
          submitButton.textContent = "Enviar";
        }
      }
    });

    setStep(0);
    updateEstimate();
    syncReferencesCount();
  </script>
</BaseLayout>
